<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>GestiónSalón</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
<header>
  <a class="brand" href="/">GestiónSalón</a>
  <nav>
    <% if (user) { %>
      <a href="/salones">Salones</a>
      <a href="/reservas">Reservas</a>
      <a href="/pagos">Pagos</a>
      <% if (user.rol === 'admin') { %><a href="/clientes">Clientes</a><% } %>
      <a href="/clientes/me">Mi perfil</a>
      <form method="post" action="/logout" style="display:inline">
        <button class="link">Salir (<%= user.nombre %>)</button>
      </form>
    <% } else { %>
      <a href="/login">Ingresar</a>
      <a href="/registro">Registrarse</a>
    <% } %>
  </nav>
</header>
<main>
<% if (flash) { %><div class="flash"><%= flash %></div><% } %>
